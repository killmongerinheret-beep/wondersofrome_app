# Copy this file to .env and fill in your values
# For brand-specific builds copy to .env.wondersofrome or .env.ticketsinrome

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
EXPO_PUBLIC_SITE_ID=wondersofrome

# Optional brand/legal URLs (defaults derived from site id)
EXPO_PUBLIC_BRAND_DOMAIN=https://wondersofrome.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://wondersofrome.com/privacy-policy
EXPO_PUBLIC_TERMS_URL=https://wondersofrome.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://wondersofrome.com/support

# content provider: payload | sanity
EXPO_PUBLIC_CONTENT_PROVIDER=payload

# Payload CMS base URL (your website / API host)
EXPO_PUBLIC_PAYLOAD_BASE_URL=https://wondersofrome.com

# Optional: if your collection slugs differ
EXPO_PUBLIC_PAYLOAD_SIGHTS_COLLECTION=sights
EXPO_PUBLIC_PAYLOAD_TOURS_COLLECTION=tours
EXPO_PUBLIC_PAYLOAD_AUDIO_TOURS_COLLECTION=audio-tours
EXPO_PUBLIC_PAYLOAD_PRODUCTS_COLLECTION=products

# Optional audio CDN (fallback for building audio URLs)
EXPO_PUBLIC_AUDIO_CDN_BASE_URL=https://cdn.yourdomain.com
